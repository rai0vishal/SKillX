# ─── Server ────────────────────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string
PORT=5000
NODE_ENV=production

# ─── Frontend URL (CORS allowlist) ─────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://your-frontend-domain.vercel.app
CLIENT_URL=https://your-frontend-domain.vercel.app

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Firebase Admin SDK (server-side token verification) ───────────────────────
# These 3 vars are read by src/config/firebaseAdmin.js
# Get them from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (with literal \n — do NOT expand to real newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
